# ============================================================================
# AI LinkedIn Content Automation — Environment Variables
# Copy to `.env` and fill in. NEVER commit `.env`. All vars are validated at
# boot by src/config (zod) — the app fails fast if a required var is missing.
# ============================================================================

# --- Core ---------------------------------------------------------------------
NODE_ENV=development                 # development | production
LOG_LEVEL=info                       # trace | debug | info | warn | error
TZ=UTC                               # scheduler timezone reference
APP_BASE_URL=https://your-domain.com # public HTTPS base (OAuth callback + Telegram webhook)
PORT=3000

# --- Security -----------------------------------------------------------------
# 32-byte key (hex/base64) used to AES-encrypt OAuth tokens & secrets at rest.
SECRET_KEY=change-me-32-byte-random-key

# --- Database (PostgreSQL) ----------------------------------------------------
DATABASE_URL=postgresql://linkedin:linkedin@localhost:5432/linkedin?schema=public
POSTGRES_USER=linkedin
POSTGRES_PASSWORD=linkedin
POSTGRES_DB=linkedin

# (No Redis/queue — the pipeline runs in-process via node-cron. See docs/ARCHITECTURE.md.)

# --- LLM providers (pluggable) ------------------------------------------------
LLM_PROVIDER=anthropic               # anthropic | openai  (default writer)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8      # writing/synthesis model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o                  # fallback writer / utility

# --- Image generation ---------------------------------------------------------
IMAGE_PROVIDER=openai                # openai | stability | none
OPENAI_IMAGE_MODEL=gpt-image-1       # AI hero images (optional)
STABILITY_API_KEY=                   # only if IMAGE_PROVIDER=stability

# --- Research / trending topics ----------------------------------------------
# Used by the ResearchService to pull trending items. Pick whatever you wire up.
NEWS_API_KEY=                        # e.g. newsapi.org (optional)
SEARCH_API_KEY=                      # e.g. Tavily/SerpAPI/Brave (optional)

# --- LinkedIn (Official API) --------------------------------------------------
# Create a LinkedIn Developer App and request the "Share on LinkedIn" /
# Community Management product. See docs/LINKEDIN_INTEGRATION.md.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://your-domain.com/auth/linkedin/callback
LINKEDIN_SCOPES=openid,profile,email,w_member_social
LINKEDIN_API_VERSION=202401          # sent as the LinkedIn-Version header (YYYYMM)

# --- Telegram (review + alerts) -----------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                    # your user/chat id that receives drafts & alerts
TELEGRAM_USE_WEBHOOK=false           # true (webhook via APP_BASE_URL) | false (long polling)

# --- Scheduling / behavior ----------------------------------------------------
DEFAULT_MODE=draft                   # draft | auto | silent
DAILY_POST_CRON=0 9 * * *            # default slot: 09:00 daily
ASSETS_DIR=./data/assets             # where rendered images/PDFs are stored
