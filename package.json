{
  "name": "linkedin-content-automation",
  "version": "0.1.0",
  "description": "AI-powered LinkedIn content automation system",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "linkedin:auth": "tsx src/cli/linkedin-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@grammyjs/runner": "^2.0.3",
    "@prisma/client": "^6.9.0",
    "croner": "^9.0.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "grammy": "^1.36.3",
    "openai": "^4.103.0",
    "p-retry": "^6.2.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^24.9.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.27.0",
    "@eslint/js": "^9.27.0",
    "typescript-eslint": "^8.32.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
